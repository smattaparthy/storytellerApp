# Environment variables for Storyteller App
# -----------------------------------------------------------------------------
# Copy this file to .env in the project root (storyteller-app/.env) and fill in your actual values.
# The backend application (run from storyteller-app/backend/) is configured to load this .env file.
# -----------------------------------------------------------------------------

# === Google AI Services ===
# Obtain these from your Google Cloud Console.
# Ensure the necessary APIs (Generative Language API for Gemini, Vertex AI API for Imagen) are enabled.
GOOGLE_API_KEY="your_google_api_key_here"
GEMINI_MODEL="gemini-pro"
# For Imagen, specify the model identifier, e.g., "imagegeneration@0.0.2", "imagen-2" might be too generic.
# Check Google Cloud documentation for the correct model endpoint/name for Imagen via Vertex AI.
IMAGEN_MODEL="imagegeneration@0.0.2" # Or your specific Imagen model

# === Database Configuration ===
# The backend (`config.py`) provides a default, absolute path to:
# storyteller-app/database/storyteller.db
# You can override this by uncommenting and setting DATABASE_URL below.
#
# If you override, use a valid SQLAlchemy connection string. Examples:
# For SQLite (ensure path is correct relative to backend CWD or use absolute path):
# If backend is run from `storyteller-app/backend/` (default setup):
# DATABASE_URL="sqlite+aiosqlite:///../database/storyteller.db"
# Or using an absolute path (replace with your actual path):
# DATABASE_URL="sqlite+aiosqlite:////path/to/your/storyteller-app/database/storyteller.db"
#
# The default configured in `config.py` is generally recommended for simplicity:
# DATABASE_URL="sqlite+aiosqlite:///./database/storyteller.db"
# (This specific line in the .env.example is illustrative of what *would* be resolved if `./` was relative to this .env file for pydantic,
# but the backend `config.py` now generates an absolute path by default making this less of a concern unless overridden.)
# The important part is: if you set DATABASE_URL here, it *overrides* the smart default.

# To use the default calculated by the application (recommended for most setups):
# Simply leave DATABASE_URL commented out or remove it from this .env file.

# If you uncomment and set DATABASE_URL, make sure it's correct:
# DATABASE_URL=

# === Backend Server Configuration ===
# CORS_ORIGINS: A JSON string representing a list of allowed origins.
# The default in `config.py` is '["http://localhost:5173", "http://localhost:3000"]'
# (Vite default port and a common alternative).
# Update if your frontend runs on a different port during development.
CORS_ORIGINS_STR='["http://localhost:5173", "http://localhost:3000"]'

# === Story Generation Parameters ===
MAX_STORY_LENGTH="300"
MIN_STORY_LENGTH="200"
MAX_IMAGES_PER_STORY="2"

# === Optional: Application Behavior ===
# DEBUG_MODE="True" # Example: if you add a DEBUG_MODE setting in config.py
# LOG_LEVEL="INFO"  # Example: if you add a LOG_LEVEL setting in config.py
